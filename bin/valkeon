#!/usr/bin/env bash
#
# `valkeon` — launch Valkeon Workbench from the shell, optionally opening a
# project directory:
#
#   valkeon            # open the workbench (home screen)
#   valkeon .          # open the current directory as a project
#   valkeon ~/work/api # open a specific project
#
# Multiple instances are allowed, so each call opens its own window — run it in
# several directories to work on them side by side.
#
# Point it at a specific build with VALKEON_BIN (a .app on macOS, or the
# executable on Linux); otherwise it auto-detects an installed app.
set -euo pipefail

# Resolve the first path argument to an absolute path (the app opens it as a
# project); anything starting with `-` is passed through as a flag.
project_arg=()
passthrough=()
if [[ $# -gt 0 && "${1:0:1}" != "-" ]]; then
  target="$1"; shift
  project_arg=("$(cd "$target" 2>/dev/null && pwd || echo "$target")")
fi
passthrough=("$@")

case "$(uname -s)" in
  Darwin)
    APP="${VALKEON_BIN:-}"
    if [[ -z "$APP" ]]; then
      for candidate in \
        "/Applications/Valkeon Workbench.app" \
        "$HOME/Applications/Valkeon Workbench.app"; do
        if [[ -d "$candidate" ]]; then APP="$candidate"; break; fi
      done
    fi
    if [[ -z "$APP" ]]; then
      echo "valkeon: could not find Valkeon Workbench.app. Set VALKEON_BIN to it." >&2
      exit 1
    fi
    # -n forces a new instance so each call opens its own window.
    exec open -n -a "$APP" --args \
      ${project_arg[@]+"${project_arg[@]}"} ${passthrough[@]+"${passthrough[@]}"}
    ;;
  *)
    APP_BIN="${VALKEON_BIN:-$(command -v valkeon-workbench || true)}"
    if [[ -z "$APP_BIN" ]]; then
      for candidate in \
        "/opt/Valkeon Workbench/valkeon-workbench" \
        "$HOME/.local/bin/valkeon-workbench"; do
        if [[ -x "$candidate" ]]; then APP_BIN="$candidate"; break; fi
      done
    fi
    if [[ -z "$APP_BIN" ]]; then
      echo "valkeon: could not find the installed app (valkeon-workbench)." >&2
      echo "Install it first, or set VALKEON_BIN — see the README 'Installation' section." >&2
      exit 1
    fi
    FLAGS=()
    if grep -qiE "(microsoft|wsl)" /proc/version 2>/dev/null; then
      # Under WSL the Chromium sandbox usually can't initialize; disable it.
      FLAGS+=(--no-sandbox)
      # WSLg has no cursor theme, so hover/resize cursors look off. Point Xcursor
      # at Adwaita (pulled in by the app's GTK deps) for this process ONLY — this
      # is inherited just by the app we launch, never the shell or other apps, and
      # only under WSL. Respect the user's own XCURSOR_* if they set them.
      : "${XCURSOR_THEME:=Adwaita}"; export XCURSOR_THEME
      : "${XCURSOR_SIZE:=24}"; export XCURSOR_SIZE
    fi
    # Detach so the terminal stays usable while the app runs.
    nohup "$APP_BIN" ${FLAGS[@]+"${FLAGS[@]}"} \
      ${project_arg[@]+"${project_arg[@]}"} ${passthrough[@]+"${passthrough[@]}"} \
      </dev/null >/dev/null 2>&1 &
    disown 2>/dev/null || true
    ;;
esac
